import OpenAI from "openai";

export async function POST(req: Request) {

  try {

    const body = await req.json();
    const chatText = body.text;

    if (!process.env.OPENAI_API_KEY) {
      return Response.json(
        { error: "OpenAI API key missing" },
        { status: 500 }
      );
    }

    const openai = new OpenAI({
      apiKey: process.env.OPENAI_API_KEY
    });

    const completion = await openai.chat.completions.create({
      model: "gpt-4o-mini",
      messages: [
        {
          role: "user",
          content: `
You are an AI conversation analyst that studies messaging behavior.

Analyze the conversation carefully and provide a structured report.

Evaluate the following factors:

1. Interest Score (0–100)
How interested the other person appears based on engagement, tone, and responses.

2. Flirting Level
Low / Medium / High based on tone, emojis, friendliness, teasing.

3. Ghosting Risk
Low / Medium / High depending on response enthusiasm and engagement.

4. Effort Balance
Estimate effort in the conversation.
Return:
You: X%
Them: X%

5. Conversation Energy
Low / Medium / High depending on excitement, emojis, and message tone.

6. Curiosity Level
Low / Medium / High depending on whether the other person asks questions or tries to continue the conversation.

7. Short Verdict
A short 1–2 sentence human-style insight explaining the relationship dynamic.

Return the result EXACTLY in this format:

Interest Score: <number>

Flirting Level: <Low / Medium / High>

Ghosting Risk: <Low / Medium / High>

Effort Balance:
You: <percentage>
Them: <percentage>

Conversation Energy: <Low / Medium / High>

Curiosity Level: <Low / Medium / High>

Verdict: <short explanation>

Conversation:
${chatText}
`
        }
      ]
    });

    return Response.json({
      result: completion.choices[0].message.content
    });

  } catch (error: any) {

    console.error("API ERROR:", error);

    return Response.json(
      { error: error.message || "Unknown server error" },
      { status: 500 }
    );
  }
}
