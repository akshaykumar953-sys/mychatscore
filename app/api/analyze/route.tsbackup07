import OpenAI from "openai";
import { LRUCache } from "lru-cache";

/* -------- RATE LIMIT CACHE -------- */

const rateLimit = new LRUCache<string, number>({
  max: 500,
  ttl: 1000 * 60
});

/* -------- REQUEST DELAY MAP -------- */

const requestMap = new Map<string, number>();

/* -------- CHAT VALIDATION -------- */

function isValidConversation(text: string) {
  const lines = text
    .split("\n")
    .map(l => l.trim())
    .filter(l => l.length > 0);

  if (lines.length < 4) return false;

  // ❗ Reject if too many long lines (articles, posts, etc.)
  const longLines = lines.filter(l => l.length > 120).length;
  if (longLines / lines.length > 0.4) return false;

// ❗ RELAX short line check (WhatsApp OCR safe)
const shortLines = lines.filter(l => l.length < 120).length;

if (shortLines / lines.length < 0.4) {
  const hasMultiLine = lines.length >= 4;
  if (!hasMultiLine) return false;
}


  // ❗ Detect conversational words (stronger)
// ❗ RELAXED SIGNAL DETECTION (supports Hindi + natural chat)

const hasWords = lines.some(l => l.split(" ").length >= 2);

const hasEmotions = /(😂|😅|🙂|👍|lol|haha)/i.test(text);

// allow either meaningful sentences OR emojis/reactions
if (!hasWords && !hasEmotions) return false;
  
const uniqueLines = new Set(lines);

// ❗ RELAX repetition check (WhatsApp safe)
if (uniqueLines.size < lines.length * 0.3) {
  const hasSentence = lines.some(l => l.split(" ").length >= 3);

  if (!hasSentence) return false;
}
  // ❗ Detect back-and-forth pattern (VERY IMPORTANT)
  let alternation = 0;

  for (let i = 1; i < lines.length; i++) {
    if (lines[i] !== lines[i - 1]) alternation++;
  }

  const alternationRatio = alternation / lines.length;

// ❗ RELAXED for WhatsApp OCR
if (alternationRatio < 0.3) {
  // allow if we detect at least 2 participants
  const possibleNames = new Set(
    lines.map(l => l.split(":")[0]).filter(l => l.length < 20)
  );

  if (possibleNames.size < 2) return false;
}

// ❗ FLEXIBLE SPEAKER DETECTION (WORKS FOR WHATSAPP OCR)

const possibleSpeakers = new Set(
  lines
    .map(l => l.split(":")[0].trim())
    .filter(l => l.length > 0 && l.length < 25)
);

// must have at least 2 participants
if (possibleSpeakers.size < 2) {
  return false;
}
  return true;
}

export async function POST(req: Request) {
  try {
    const body = await req.json();

    const ip =
      req.headers.get("x-forwarded-for") ||
      req.headers.get("x-real-ip") ||
      "unknown";

    /* -------- RATE LIMIT -------- */

    const count = rateLimit.get(ip) || 0;

    if (count >= 15) {
      return Response.json(
        { error: "Too many requests. Please wait." },
        { status: 429 }
      );
    }

    rateLimit.set(ip, count + 1);

    /* -------- COOLDOWN -------- */

    const now = Date.now();
    const lastRequest = requestMap.get(ip) || 0;

    if (now - lastRequest < 3000) {
      return Response.json(
        { error: "Please wait a few seconds before analyzing again." },
        { status: 429 }
      );
    }

    requestMap.set(ip, now);

    const chatText = body.text;

    /* -------- INPUT VALIDATION -------- */

    if (!chatText || chatText.trim().length === 0) {
      return Response.json(
        { error: "Please paste a chat conversation first." },
        { status: 400 }
      );
    }

    const MAX_CHAT_LENGTH = 3000;

    if (chatText.length > MAX_CHAT_LENGTH) {
      return Response.json(
        {
          error:
            "Chat too long. Please analyze a shorter conversation (max ~300 messages)."
        },
        { status: 400 }
      );
    }

    /* -------- CHAT VALIDATION -------- */

    if (!isValidConversation(chatText)) {
      return Response.json(
        {
          error:
            "⚠️ Please upload a valid chat conversation (must include at least 2 people)."
        },
        { status: 400 }
      );
    }

    /* -------- CHECK API KEY -------- */

    if (!process.env.OPENAI_API_KEY) {
      return Response.json(
        { error: "Server configuration error." },
        { status: 500 }
      );
    }

    const openai = new OpenAI({
      apiKey: process.env.OPENAI_API_KEY
    });

    /* -------- AI ANALYSIS -------- */

    const completion = await openai.chat.completions.create({
      model: "gpt-4o-mini",
      temperature: 0,
      max_tokens: 200,
      messages: [
        {
          role: "system",
          content: `
You analyze chat conversations and return relationship insights.

Detect two participant names if present (e.g., "Akshay: message").
If names are unclear use "User" and "Other Person".

Always mention the detected names inside the explanation.
`
        },
        {
          role: "user",
          content: `
Analyze this conversation and return EXACTLY this format.

Interest Score: <0-100>

Flirting Level: <Low / Medium / High>

Ghosting Risk: <Low / Medium / High>

Effort Balance:
User: X%
Other Person: X%

Conversation Energy: <Low / Medium / High>

Curiosity Level: <Low / Medium / High>

Verdict: A short explanation mentioning the detected names.

Conversation:

${chatText}
`
        }
      ]
    });

    return Response.json({
      result: completion.choices[0].message.content
    });

  } catch (error: any) {
    console.error("Analyze API Error:", error);

    return Response.json(
      { error: "Analysis failed. Please try again." },
      { status: 500 }
    );
  }
}
